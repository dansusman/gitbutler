{
	"$schema": "../gen/schemas/desktop-schema.json",
	"identifier": "main",
	"description": "permissions for gitbutler tauri",
	"windows": ["*"],
	"local": true,
	"permissions": [
		"core:default",
		"core:event:default",
		"core:window:allow-start-dragging",
		"core:window:allow-set-title",
		"core:window:default",
		"dialog:allow-open",
		"dialog:allow-save",
		"fs:allow-read-file",
		"fs:allow-write-text-file",
		"fs:allow-cache-read-recursive",
		"log:default",
		"process:default",
		"shell:allow-open",
		"store:default",
		"updater:default",
		"clipboard-manager:allow-read-text",
		"clipboard-manager:allow-write-text",
		"deep-link:default",
		"allow-custom-commands"
	]
}
